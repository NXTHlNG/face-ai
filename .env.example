# Скопируй в .env: copy .env.example .env
# См. README — префикс FACE_AI_

FACE_AI_RULES_VERSION=1.0.0
FACE_AI_MODELS_DIR=models
# mediapipe | dlib81 (для dlib81: pip install -r requirements-dlib.txt)
FACE_AI_LANDMARK_BACKEND=mediapipe
FACE_AI_FACE_PARSING_ENABLED=true
FACE_AI_YAKHYO_ONNX_URL=https://github.com/yakhyo/face-parsing/releases/download/v0.0.2/resnet34.onnx
FACE_AI_YAKHYO_ONNX_FILENAME=yakhyo_resnet34.onnx
FACE_AI_FACE_PARSING_ONNX_PATH=
FACE_AI_SKIP_ANALYSIS_IF_PHOTO_POOR=true
# Насколько поднять верх bbox лица (доля высоты сырого min/max по точкам) — лоб у mesh часто ниже линии волос
FACE_AI_FACE_BBOX_FOREHEAD_PAD_RATIO=0.22
FACE_AI_DEBUG_SAVE_IMAGES=false
FACE_AI_DEBUG_OUTPUT_DIR=debug_output
