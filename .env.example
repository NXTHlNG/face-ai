# Face AI — переменные окружения (префикс FACE_AI_)
# Путь к .env: корень проекта face-ai/

# Версия набора правил в ответе API
FACE_AI_RULES_VERSION=1.0.0

# Каталог для моделей (MediaPipe task, yakhyo ONNX)
FACE_AI_MODELS_DIR=models

# Лендмарки: mediapipe (дефолт) или dlib81 — см. vendor/shape_predictor_81_face_landmarks и requirements-dlib.txt
FACE_AI_LANDMARK_BACKEND=mediapipe

# URL модели Face Landmarker (скачивание при первом запуске)
# FACE_AI_MEDIAPIPE_MODEL_URL=https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/latest/face_landmarker.task

# Face parsing: false — только fallback-макеты по лендмаркам
FACE_AI_FACE_PARSING_ENABLED=true

# Скачивание yakhyo (resnet34 по умолчанию; для resnet18 смени URL и имя файла)
FACE_AI_YAKHYO_ONNX_URL=https://github.com/yakhyo/face-parsing/releases/download/v0.0.2/resnet34.onnx
FACE_AI_YAKHYO_ONNX_FILENAME=yakhyo_resnet34.onnx

# Свой ONNX парсинга (оставь пустым для автоскачивания yakhyo)
FACE_AI_FACE_PARSING_ONNX_PATH=

# Верх bbox лица: поднимаем на долю высоты (сеть MediaPipe редко покрывает весь лоб до линии волос)
FACE_AI_FACE_BBOX_FOREHEAD_PAD_RATIO=0.22

# Gate качества фото: true — при плохом фото только совет переснять
FACE_AI_SKIP_ANALYSIS_IF_PHOTO_POOR=true

# Отладочные снимки в debug_output/<timestamp>_<id>/
FACE_AI_DEBUG_SAVE_IMAGES=true
FACE_AI_DEBUG_OUTPUT_DIR=debug_output
