# Face AI — переменные окружения (префикс FACE_AI_)

FACE_AI_RULES_VERSION=2.0.0
FACE_AI_MODELS_DIR=models

# Landmarks
FACE_AI_LANDMARK_BACKEND=mediapipe

# Parsing: bisenet_resnet34 | farl_b | segface | landmark_fallback
FACE_AI_PARSING_BACKEND=farl_b
FACE_AI_FACE_PARSING_ENABLED=true
FACE_AI_PARSING_FALLBACK_CHAIN=bisenet_resnet34,farl_b,landmark_fallback

FACE_AI_YAKHYO_ONNX_URL=https://github.com/yakhyo/face-parsing/releases/download/v0.0.2/resnet34.onnx
FACE_AI_YAKHYO_ONNX_FILENAME=yakhyo_resnet34.onnx

# Color / season
FACE_AI_SKIN_COLOR_BACKEND=mean_lab
# AUA: brightness_clusters (default) | parsing_mask
FACE_AI_LIP_COLOR_BACKEND=brightness_clusters
# Season: ensemble (Munsell + Park + swatch + wrist) | munsell_lookup | park_imcom18
FACE_AI_SEASON_CLASSIFIER=ensemble
FACE_AI_UNDERTONE_SOURCES=face
# Park IMCOM'18 only (when FACE_AI_SEASON_CLASSIFIER=park_imcom18)
FACE_AI_PARK_CONTRAST_THRESHOLD=13.0
FACE_AI_PARK_USE_CIELAB_L_SCALE=true

# Mask preview in API response
FACE_AI_MASK_PREVIEW_ENABLED=true

# LLM analysis (primary semantics; rules fallback when disabled)
FACE_AI_LLM_ENABLED=true
# FACE_AI_LLM_API_URL=https://api.openai.com/v1/chat/completions
# FACE_AI_LLM_API_KEY=

# Generative try-on Model API; none = CV-only
FACE_AI_GENERATIVE_API_URL=none
# FACE_AI_GENERATIVE_API_KEY=

# Try-on defaults
FACE_AI_TRYON_DEFAULT_CATEGORIES=makeup,glasses,hairstyle
FACE_AI_OUTFIT_INLINE_MIN_RATIO=0.15

FACE_AI_SKIP_ANALYSIS_IF_PHOTO_POOR=true
FACE_AI_DEBUG_SAVE_IMAGES=false
FACE_AI_DEBUG_OUTPUT_DIR=debug_output

# Optional ML parsing (install requirements-parsing-ml.txt)
# FaRL-B backend default: farl/celebm/448 (CelebAMask-HQ). Alt: farl/lapa/448
# FACE_AI_FARL_MODEL_NAME=farl/celebm/448
# SegFace (vendor/segface + weights from HuggingFace)
# python scripts/download_segface_weights.py
# FACE_AI_SEGFACE_MODEL=mobilenet
# FACE_AI_SEGFACE_INPUT_SIZE=512
# FACE_AI_SEGFACE_WEIGHTS_PATH=models/segface/mobilenet_celeba_512/model_299.pt
