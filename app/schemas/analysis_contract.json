{
  "$defs": {
    "AnalysisPalette": {
      "description": "Colors extracted from the face and season reference swatches used in classification.",
      "properties": {
        "face": {
          "items": {
            "$ref": "#/$defs/PaletteSwatch"
          },
          "title": "Face",
          "type": "array"
        },
        "season_reference": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/PaletteSwatch"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Season Reference"
        }
      },
      "title": "AnalysisPalette",
      "type": "object"
    },
    "ColorFeatures": {
      "properties": {
        "skin_ab_mean": {
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "Skin Ab Mean",
          "type": "array"
        },
        "skin_chroma_hint": {
          "title": "Skin Chroma Hint",
          "type": "number"
        },
        "hair_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hair L Mean"
        },
        "hair_ab_mean": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hair Ab Mean"
        },
        "iris_ab_mean": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iris Ab Mean"
        },
        "eye_color_hint": {
          "enum": [
            "blue",
            "gray",
            "green",
            "hazel",
            "amber",
            "light_brown",
            "brown",
            "dark_brown",
            "unknown"
          ],
          "title": "Eye Color Hint",
          "type": "string"
        },
        "eye_color_label_ru": {
          "title": "Eye Color Label Ru",
          "type": "string"
        },
        "eye_color_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Eye Color Confidence",
          "type": "number"
        },
        "undertone_hint": {
          "enum": [
            "warm",
            "cool",
            "neutral"
          ],
          "title": "Undertone Hint",
          "type": "string"
        },
        "depth_hint": {
          "enum": [
            "light",
            "deep",
            "medium"
          ],
          "title": "Depth Hint",
          "type": "string"
        },
        "seasonal_twelve": {
          "enum": [
            "light_spring",
            "true_spring",
            "bright_spring",
            "light_summer",
            "true_summer",
            "soft_summer",
            "soft_autumn",
            "true_autumn",
            "deep_autumn",
            "deep_winter",
            "true_winter",
            "bright_winter",
            "unknown"
          ],
          "title": "Seasonal Twelve",
          "type": "string"
        },
        "seasonal_twelve_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Seasonal Twelve Confidence",
          "type": "number"
        },
        "seasonal_guess": {
          "enum": [
            "spring",
            "summer",
            "autumn",
            "winter",
            "unknown"
          ],
          "title": "Seasonal Guess",
          "type": "string"
        },
        "seasonal_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Seasonal Confidence",
          "type": "number"
        }
      },
      "required": [
        "skin_ab_mean",
        "skin_chroma_hint",
        "eye_color_hint",
        "eye_color_label_ru",
        "eye_color_confidence",
        "undertone_hint",
        "depth_hint",
        "seasonal_twelve",
        "seasonal_twelve_confidence",
        "seasonal_guess",
        "seasonal_confidence"
      ],
      "title": "ColorFeatures",
      "type": "object"
    },
    "ConfidenceBreakdown": {
      "properties": {
        "overall": {
          "maximum": 1,
          "minimum": 0,
          "title": "Overall",
          "type": "number"
        },
        "geometry": {
          "maximum": 1,
          "minimum": 0,
          "title": "Geometry",
          "type": "number"
        },
        "contrast": {
          "maximum": 1,
          "minimum": 0,
          "title": "Contrast",
          "type": "number"
        },
        "color": {
          "maximum": 1,
          "minimum": 0,
          "title": "Color",
          "type": "number"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "overall",
        "geometry",
        "contrast",
        "color"
      ],
      "title": "ConfidenceBreakdown",
      "type": "object"
    },
    "ContrastMetrics": {
      "properties": {
        "skin_L_mean": {
          "title": "Skin L Mean",
          "type": "number"
        },
        "brow_L_mean": {
          "title": "Brow L Mean",
          "type": "number"
        },
        "hair_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hair L Mean"
        },
        "iris_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iris L Mean"
        },
        "lip_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lip L Mean"
        },
        "brow_skin_delta_L": {
          "title": "Brow Skin Delta L",
          "type": "number"
        },
        "hair_skin_delta_L": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hair Skin Delta L"
        },
        "iris_skin_delta_L": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iris Skin Delta L"
        },
        "lip_skin_delta_L": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lip Skin Delta L"
        },
        "value_contrast_index": {
          "maximum": 100,
          "minimum": 0,
          "title": "Value Contrast Index",
          "type": "number"
        },
        "contrast_bucket": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Contrast Bucket",
          "type": "string"
        },
        "parsing_used": {
          "default": false,
          "title": "Parsing Used",
          "type": "boolean"
        }
      },
      "required": [
        "skin_L_mean",
        "brow_L_mean",
        "brow_skin_delta_L",
        "value_contrast_index",
        "contrast_bucket"
      ],
      "title": "ContrastMetrics",
      "type": "object"
    },
    "DebugArtifact": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "kind": {
          "enum": [
            "image",
            "text",
            "json"
          ],
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "name",
        "kind"
      ],
      "title": "DebugArtifact",
      "type": "object"
    },
    "DebugBundle": {
      "properties": {
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "artifacts": {
          "items": {
            "$ref": "#/$defs/DebugArtifact"
          },
          "title": "Artifacts",
          "type": "array"
        }
      },
      "required": [
        "run_id"
      ],
      "title": "DebugBundle",
      "type": "object"
    },
    "GeometryMetrics": {
      "properties": {
        "cheekbone_width_norm": {
          "title": "Cheekbone Width Norm",
          "type": "number"
        },
        "jaw_to_cheek_ratio": {
          "title": "Jaw To Cheek Ratio",
          "type": "number"
        },
        "face_aspect_ratio": {
          "title": "Face Aspect Ratio",
          "type": "number"
        },
        "forehead_to_cheek_ratio": {
          "title": "Forehead To Cheek Ratio",
          "type": "number"
        },
        "vertical_thirds_balance": {
          "maximum": 1,
          "minimum": 0,
          "title": "Vertical Thirds Balance",
          "type": "number"
        },
        "face_shape": {
          "enum": [
            "oval",
            "round",
            "square",
            "heart",
            "triangle",
            "oblong",
            "diamond",
            "unknown"
          ],
          "title": "Face Shape",
          "type": "string"
        },
        "face_shape_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Face Shape Confidence",
          "type": "number"
        },
        "geometry_landmark_set": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Geometry Landmark Set"
        }
      },
      "required": [
        "cheekbone_width_norm",
        "jaw_to_cheek_ratio",
        "face_aspect_ratio",
        "forehead_to_cheek_ratio",
        "vertical_thirds_balance",
        "face_shape",
        "face_shape_confidence"
      ],
      "title": "GeometryMetrics",
      "type": "object"
    },
    "MaskPreview": {
      "properties": {
        "skin_mask_b64": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skin Mask B64"
        },
        "combined_features_b64": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Combined Features B64"
        }
      },
      "title": "MaskPreview",
      "type": "object"
    },
    "MetricsBundle": {
      "properties": {
        "geometry": {
          "$ref": "#/$defs/GeometryMetrics"
        },
        "contrast": {
          "$ref": "#/$defs/ContrastMetrics"
        },
        "color_features": {
          "$ref": "#/$defs/ColorFeatures"
        },
        "parsing": {
          "$ref": "#/$defs/ParsingMeta"
        },
        "seasonal": {
          "anyOf": [
            {
              "$ref": "#/$defs/SeasonalAnalysis"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "analysis_palette": {
          "anyOf": [
            {
              "$ref": "#/$defs/AnalysisPalette"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mask_preview": {
          "anyOf": [
            {
              "$ref": "#/$defs/MaskPreview"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "geometry",
        "contrast",
        "color_features",
        "parsing"
      ],
      "title": "MetricsBundle",
      "type": "object"
    },
    "MunsellScores": {
      "properties": {
        "undertone": {
          "maximum": 5,
          "minimum": 1,
          "title": "Undertone",
          "type": "integer"
        },
        "chroma": {
          "maximum": 5,
          "minimum": 1,
          "title": "Chroma",
          "type": "integer"
        },
        "value": {
          "maximum": 5,
          "minimum": 1,
          "title": "Value",
          "type": "integer"
        },
        "contrast": {
          "maximum": 5,
          "minimum": 1,
          "title": "Contrast",
          "type": "integer"
        }
      },
      "required": [
        "undertone",
        "chroma",
        "value",
        "contrast"
      ],
      "title": "MunsellScores",
      "type": "object"
    },
    "PaletteSwatch": {
      "properties": {
        "region": {
          "title": "Region",
          "type": "string"
        },
        "rgb": {
          "maxItems": 3,
          "minItems": 3,
          "prefixItems": [
            {
              "type": "integer"
            },
            {
              "type": "integer"
            },
            {
              "type": "integer"
            }
          ],
          "title": "Rgb",
          "type": "array"
        },
        "hex": {
          "title": "Hex",
          "type": "string"
        },
        "lab_opencv": {
          "maxItems": 3,
          "minItems": 3,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "Lab Opencv",
          "type": "array"
        },
        "lab_cielab": {
          "anyOf": [
            {
              "maxItems": 3,
              "minItems": 3,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lab Cielab"
        }
      },
      "required": [
        "region",
        "rgb",
        "hex",
        "lab_opencv"
      ],
      "title": "PaletteSwatch",
      "type": "object"
    },
    "ParsingMeta": {
      "properties": {
        "used_model": {
          "title": "Used Model",
          "type": "boolean"
        },
        "parsing_backend": {
          "default": "landmark_fallback",
          "enum": [
            "bisenet_resnet34",
            "farl_b",
            "segface",
            "landmark_fallback"
          ],
          "title": "Parsing Backend",
          "type": "string"
        },
        "glasses_mask_ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Glasses Mask Ratio"
        }
      },
      "required": [
        "used_model"
      ],
      "title": "ParsingMeta",
      "type": "object"
    },
    "PhotoQuality": {
      "properties": {
        "sharpness_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Sharpness Score",
          "type": "number"
        },
        "exposure_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Exposure Score",
          "type": "number"
        },
        "face_coverage_ratio": {
          "maximum": 1,
          "minimum": 0,
          "title": "Face Coverage Ratio",
          "type": "number"
        },
        "passes_gate": {
          "title": "Passes Gate",
          "type": "boolean"
        },
        "issues": {
          "items": {
            "type": "string"
          },
          "title": "Issues",
          "type": "array"
        }
      },
      "required": [
        "sharpness_score",
        "exposure_score",
        "face_coverage_ratio",
        "passes_gate"
      ],
      "title": "PhotoQuality",
      "type": "object"
    },
    "RecommendationItem": {
      "properties": {
        "category": {
          "enum": [
            "glasses",
            "hair",
            "makeup",
            "clothing_colors",
            "jewelry",
            "general"
          ],
          "title": "Category",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "rule_id": {
          "title": "Rule Id",
          "type": "string"
        },
        "rule_version": {
          "title": "Rule Version",
          "type": "string"
        },
        "based_on": {
          "additionalProperties": true,
          "title": "Based On",
          "type": "object"
        }
      },
      "required": [
        "category",
        "title",
        "detail",
        "rule_id",
        "rule_version"
      ],
      "title": "RecommendationItem",
      "type": "object"
    },
    "SeasonScore": {
      "properties": {
        "season": {
          "title": "Season",
          "type": "string"
        },
        "probability": {
          "maximum": 1,
          "minimum": 0,
          "title": "Probability",
          "type": "number"
        }
      },
      "required": [
        "season",
        "probability"
      ],
      "title": "SeasonScore",
      "type": "object"
    },
    "SeasonalAnalysis": {
      "properties": {
        "seasonal_guess": {
          "enum": [
            "spring",
            "summer",
            "autumn",
            "winter",
            "unknown"
          ],
          "title": "Seasonal Guess",
          "type": "string"
        },
        "seasonal_twelve": {
          "enum": [
            "light_spring",
            "true_spring",
            "bright_spring",
            "light_summer",
            "true_summer",
            "soft_summer",
            "soft_autumn",
            "true_autumn",
            "deep_autumn",
            "deep_winter",
            "true_winter",
            "bright_winter",
            "unknown"
          ],
          "title": "Seasonal Twelve",
          "type": "string"
        },
        "seasonal_sixteen": {
          "title": "Seasonal Sixteen",
          "type": "string"
        },
        "seasonal_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Seasonal Confidence",
          "type": "number"
        },
        "seasonal_twelve_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Seasonal Twelve Confidence",
          "type": "number"
        },
        "seasonal_guess_top_k": {
          "items": {
            "$ref": "#/$defs/SeasonScore"
          },
          "title": "Seasonal Guess Top K",
          "type": "array"
        },
        "seasonal_twelve_top_k": {
          "items": {
            "$ref": "#/$defs/SubtypeScore"
          },
          "title": "Seasonal Twelve Top K",
          "type": "array"
        },
        "munsell_scores": {
          "anyOf": [
            {
              "$ref": "#/$defs/MunsellScores"
            },
            {
              "additionalProperties": {
                "type": "integer"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Munsell Scores"
        },
        "skin_tone_class": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Skin Tone Class"
        },
        "undertone_hint": {
          "enum": [
            "warm",
            "cool",
            "neutral"
          ],
          "title": "Undertone Hint",
          "type": "string"
        },
        "undertone_source": {
          "default": "face",
          "enum": [
            "face",
            "wrist",
            "fused",
            "park_skin_ab"
          ],
          "title": "Undertone Source",
          "type": "string"
        },
        "classifier_contributors": {
          "additionalProperties": true,
          "title": "Classifier Contributors",
          "type": "object"
        },
        "delta_e_scores": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "number"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delta E Scores"
        },
        "seasonal_method": {
          "default": "ensemble",
          "title": "Seasonal Method",
          "type": "string"
        }
      },
      "required": [
        "seasonal_guess",
        "seasonal_twelve",
        "seasonal_sixteen",
        "seasonal_confidence",
        "seasonal_twelve_confidence",
        "undertone_hint"
      ],
      "title": "SeasonalAnalysis",
      "type": "object"
    },
    "SubtypeScore": {
      "properties": {
        "subtype": {
          "title": "Subtype",
          "type": "string"
        },
        "probability": {
          "maximum": 1,
          "minimum": 0,
          "title": "Probability",
          "type": "number"
        }
      },
      "required": [
        "subtype",
        "probability"
      ],
      "title": "SubtypeScore",
      "type": "object"
    }
  },
  "properties": {
    "photo_quality": {
      "$ref": "#/$defs/PhotoQuality"
    },
    "metrics": {
      "anyOf": [
        {
          "$ref": "#/$defs/MetricsBundle"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "confidence": {
      "$ref": "#/$defs/ConfidenceBreakdown"
    },
    "recommendations": {
      "items": {
        "$ref": "#/$defs/RecommendationItem"
      },
      "title": "Recommendations",
      "type": "array"
    },
    "debug": {
      "anyOf": [
        {
          "$ref": "#/$defs/DebugBundle"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "disclaimer": {
      "default": "Рекомендации носят ориентировочный характер; цвет и контраст зависят от освещения и камеры.",
      "title": "Disclaimer",
      "type": "string"
    }
  },
  "required": [
    "photo_quality",
    "confidence",
    "recommendations"
  ],
  "title": "AnalysisResponse",
  "type": "object"
}
