{
  "$defs": {
    "ColorFeatures": {
      "description": "Признаки для палитры / грубого цветотипа (ориентиры, не диагноз).",
      "properties": {
        "skin_ab_mean": {
          "description": "Средние a*, b* по коже (Lab).",
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "title": "Skin Ab Mean",
          "type": "array"
        },
        "skin_chroma_hint": {
          "description": "Грубая насыщенность кожи.",
          "title": "Skin Chroma Hint",
          "type": "number"
        },
        "hair_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hair L Mean"
        },
        "hair_ab_mean": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hair Ab Mean"
        },
        "iris_ab_mean": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iris Ab Mean"
        },
        "eye_color_hint": {
          "description": "Грубая категория цвета глаз по LAB радужки.",
          "enum": [
            "blue",
            "gray",
            "green",
            "hazel",
            "amber",
            "light_brown",
            "brown",
            "dark_brown",
            "unknown"
          ],
          "title": "Eye Color Hint",
          "type": "string"
        },
        "eye_color_label_ru": {
          "description": "Подпись цвета глаз на русском.",
          "title": "Eye Color Label Ru",
          "type": "string"
        },
        "eye_color_confidence": {
          "description": "Уверенность в eye_color_hint.",
          "maximum": 1,
          "minimum": 0,
          "title": "Eye Color Confidence",
          "type": "number"
        },
        "undertone_hint": {
          "description": "Подтон: кожа + при наличии волосы и радужка в a*b* (освещение искажает).",
          "enum": [
            "warm",
            "cool",
            "neutral"
          ],
          "title": "Undertone Hint",
          "type": "string"
        },
        "depth_hint": {
          "description": "Глубина (value): светлота кожи и волос в LAB.",
          "enum": [
            "light",
            "deep",
            "medium"
          ],
          "title": "Depth Hint",
          "type": "string"
        },
        "seasonal_twelve": {
          "description": "12 сезонов (англ. ключи): подтип внутри тёплого/холодного × светлота × soft/clear.",
          "enum": [
            "light_spring",
            "true_spring",
            "bright_spring",
            "light_summer",
            "true_summer",
            "soft_summer",
            "soft_autumn",
            "true_autumn",
            "deep_autumn",
            "deep_winter",
            "true_winter",
            "bright_winter",
            "unknown"
          ],
          "title": "Seasonal Twelve",
          "type": "string"
        },
        "seasonal_twelve_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Seasonal Twelve Confidence",
          "type": "number"
        },
        "seasonal_guess": {
          "description": "Родительский сезон (4), согласован с seasonal_twelve.",
          "enum": [
            "spring",
            "summer",
            "autumn",
            "winter",
            "unknown"
          ],
          "title": "Seasonal Guess",
          "type": "string"
        },
        "seasonal_confidence": {
          "description": "Уверенность в подтипе (seasonal_twelve); совпадает с seasonal_twelve_confidence.",
          "maximum": 1,
          "minimum": 0,
          "title": "Seasonal Confidence",
          "type": "number"
        }
      },
      "required": [
        "skin_ab_mean",
        "skin_chroma_hint",
        "eye_color_hint",
        "eye_color_label_ru",
        "eye_color_confidence",
        "undertone_hint",
        "depth_hint",
        "seasonal_twelve",
        "seasonal_twelve_confidence",
        "seasonal_guess",
        "seasonal_confidence"
      ],
      "title": "ColorFeatures",
      "type": "object"
    },
    "ConfidenceBreakdown": {
      "properties": {
        "overall": {
          "maximum": 1,
          "minimum": 0,
          "title": "Overall",
          "type": "number"
        },
        "geometry": {
          "maximum": 1,
          "minimum": 0,
          "title": "Geometry",
          "type": "number"
        },
        "contrast": {
          "maximum": 1,
          "minimum": 0,
          "title": "Contrast",
          "type": "number"
        },
        "color": {
          "maximum": 1,
          "minimum": 0,
          "title": "Color",
          "type": "number"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "overall",
        "geometry",
        "contrast",
        "color"
      ],
      "title": "ConfidenceBreakdown",
      "type": "object"
    },
    "ContrastMetrics": {
      "description": "Контраст между элементами лица (не HDR).",
      "properties": {
        "skin_L_mean": {
          "title": "Skin L Mean",
          "type": "number"
        },
        "brow_L_mean": {
          "title": "Brow L Mean",
          "type": "number"
        },
        "hair_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hair L Mean"
        },
        "iris_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iris L Mean"
        },
        "lip_L_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lip L Mean"
        },
        "brow_skin_delta_L": {
          "description": "|L брови − L кожи|.",
          "title": "Brow Skin Delta L",
          "type": "number"
        },
        "hair_skin_delta_L": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "|L волос − L кожи|.",
          "title": "Hair Skin Delta L"
        },
        "iris_skin_delta_L": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Iris Skin Delta L"
        },
        "lip_skin_delta_L": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lip Skin Delta L"
        },
        "value_contrast_index": {
          "description": "Сводный индекс value-contrast (0–100).",
          "maximum": 100,
          "minimum": 0,
          "title": "Value Contrast Index",
          "type": "number"
        },
        "contrast_bucket": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Contrast Bucket",
          "type": "string"
        },
        "parsing_used": {
          "default": false,
          "description": "Использовалась ли сегментационная модель.",
          "title": "Parsing Used",
          "type": "boolean"
        }
      },
      "required": [
        "skin_L_mean",
        "brow_L_mean",
        "brow_skin_delta_L",
        "value_contrast_index",
        "contrast_bucket"
      ],
      "title": "ContrastMetrics",
      "type": "object"
    },
    "GeometryMetrics": {
      "properties": {
        "cheekbone_width_norm": {
          "description": "Ширина скул / межзрачковое (условно норм.).",
          "title": "Cheekbone Width Norm",
          "type": "number"
        },
        "jaw_to_cheek_ratio": {
          "description": "Отношение ширины челюсти к ширине скул.",
          "title": "Jaw To Cheek Ratio",
          "type": "number"
        },
        "face_aspect_ratio": {
          "description": "Высота лица / ширина (ограничивающий контур).",
          "title": "Face Aspect Ratio",
          "type": "number"
        },
        "forehead_to_cheek_ratio": {
          "description": "Ширина лба / ширина скул.",
          "title": "Forehead To Cheek Ratio",
          "type": "number"
        },
        "vertical_thirds_balance": {
          "description": "Насколько равны вертикальные трети (1 — идеально ровно).",
          "maximum": 1,
          "minimum": 0,
          "title": "Vertical Thirds Balance",
          "type": "number"
        },
        "face_shape": {
          "enum": [
            "oval",
            "round",
            "square",
            "heart",
            "triangle",
            "oblong",
            "diamond",
            "unknown"
          ],
          "title": "Face Shape",
          "type": "string"
        },
        "face_shape_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Face Shape Confidence",
          "type": "number"
        },
        "geometry_landmark_set": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Источник точек: mediapipe_478 или dlib_iBUG_81.",
          "title": "Geometry Landmark Set"
        }
      },
      "required": [
        "cheekbone_width_norm",
        "jaw_to_cheek_ratio",
        "face_aspect_ratio",
        "forehead_to_cheek_ratio",
        "vertical_thirds_balance",
        "face_shape",
        "face_shape_confidence"
      ],
      "title": "GeometryMetrics",
      "type": "object"
    },
    "MetricsBundle": {
      "properties": {
        "geometry": {
          "$ref": "#/$defs/GeometryMetrics"
        },
        "contrast": {
          "$ref": "#/$defs/ContrastMetrics"
        },
        "color_features": {
          "$ref": "#/$defs/ColorFeatures"
        },
        "parsing": {
          "$ref": "#/$defs/ParsingMeta"
        }
      },
      "required": [
        "geometry",
        "contrast",
        "color_features",
        "parsing"
      ],
      "title": "MetricsBundle",
      "type": "object"
    },
    "ParsingMeta": {
      "properties": {
        "used_model": {
          "title": "Used Model",
          "type": "boolean"
        },
        "glasses_mask_ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Glasses Mask Ratio"
        }
      },
      "required": [
        "used_model"
      ],
      "title": "ParsingMeta",
      "type": "object"
    },
    "PhotoQuality": {
      "description": "Эвристики качества входного изображения.",
      "properties": {
        "sharpness_score": {
          "description": "Нормализованная резкость (Laplacian variance).",
          "maximum": 1,
          "minimum": 0,
          "title": "Sharpness Score",
          "type": "number"
        },
        "exposure_score": {
          "description": "Насколько экспозиция в допустимом диапазоне.",
          "maximum": 1,
          "minimum": 0,
          "title": "Exposure Score",
          "type": "number"
        },
        "face_coverage_ratio": {
          "description": "Доля площади изображения, занятая bbox лица.",
          "maximum": 1,
          "minimum": 0,
          "title": "Face Coverage Ratio",
          "type": "number"
        },
        "passes_gate": {
          "description": "Проходит ли фото минимальный порог для анализа.",
          "title": "Passes Gate",
          "type": "boolean"
        },
        "issues": {
          "items": {
            "type": "string"
          },
          "title": "Issues",
          "type": "array"
        }
      },
      "required": [
        "sharpness_score",
        "exposure_score",
        "face_coverage_ratio",
        "passes_gate"
      ],
      "title": "PhotoQuality",
      "type": "object"
    },
    "RecommendationItem": {
      "properties": {
        "category": {
          "enum": [
            "glasses",
            "hair",
            "makeup",
            "clothing_colors",
            "jewelry",
            "general"
          ],
          "title": "Category",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "rule_id": {
          "description": "Стабильный идентификатор правила.",
          "title": "Rule Id",
          "type": "string"
        },
        "rule_version": {
          "description": "Версия набора правил.",
          "title": "Rule Version",
          "type": "string"
        },
        "based_on": {
          "additionalProperties": true,
          "description": "Какие поля метрик задействованы (для объяснимости).",
          "title": "Based On",
          "type": "object"
        }
      },
      "required": [
        "category",
        "title",
        "detail",
        "rule_id",
        "rule_version"
      ],
      "title": "RecommendationItem",
      "type": "object"
    }
  },
  "properties": {
    "photo_quality": {
      "$ref": "#/$defs/PhotoQuality"
    },
    "metrics": {
      "anyOf": [
        {
          "$ref": "#/$defs/MetricsBundle"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Типизированные метрики; null если лицо не найдено или сработал gate качества."
    },
    "confidence": {
      "$ref": "#/$defs/ConfidenceBreakdown"
    },
    "recommendations": {
      "items": {
        "$ref": "#/$defs/RecommendationItem"
      },
      "title": "Recommendations",
      "type": "array"
    },
    "disclaimer": {
      "default": "Рекомендации носят ориентировочный характер; цвет и контраст зависят от освещения и камеры.",
      "title": "Disclaimer",
      "type": "string"
    }
  },
  "required": [
    "photo_quality",
    "confidence",
    "recommendations"
  ],
  "title": "AnalysisResponse",
  "type": "object"
}
